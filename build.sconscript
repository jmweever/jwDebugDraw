Import('env')

jw_src = 'deps/jwdebugdraw/src'

env.Append(CPPPATH=[jw_src])

def shader_to_header(target, source, env):
	with open(str(source[0]), 'r') as f:
		shader = f.read()

	lines = [l for l in shader.split('\n') if l.strip()]

	out = '#pragma once\n\n'
	out += '// Auto-generated by SConstruct from shader.gdshader - DO NOT EDIT MANUALLY!\n\n'
	out += 'namespace JW\n{\n\tconst inline auto SHADER_CODE =\n'
	for i, line in enumerate(lines):
		escaped = line.replace('\\', '\\\\').replace('"', '\\"')
		suffix = ';\n' if i == len(lines) - 1 else '\n'
		out += '\t\t"' + escaped + '\\n"' + suffix
	out += '}\n'

	with open(str(target[0]), 'w') as f:
		f.write(out)

if 'ShaderToHeader' not in env['BUILDERS']:
	env.Append(BUILDERS={'ShaderToHeader': env.Builder(action=shader_to_header)})

shader_header = env.ShaderToHeader(
	'{}/shader.hpp'.format(jw_src),
	'{}/shader.gdshader'.format(jw_src)
)

sources = Glob('deps/jwdebugdraw/src/*.cpp')
env.Depends(sources, shader_header)

Return('sources')
